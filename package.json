{
  "author": "Turo engineering",
  "description": "Turo semantic-release configuration",
  "dependencies": {
    "@aensley/semantic-release-openapi": "1.1.8",
    "@open-turo/semantic-release-jira": "^1.0.2",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.0",
    "@semantic-release/npm": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "conventional-changelog-conventionalcommits": "^10.0.0",
    "gradle-semantic-release-plugin": "^1.10.3",
    "micromatch": "^4.0.5"
  },
  "devDependencies": {
    "@open-turo/eslint-config-typescript": "23.0.1",
    "@types/lodash.template": "4.5.3",
    "@types/micromatch": "4.0.10",
    "@types/node": "25.0.3",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "9.39.2",
    "lodash": "4.18.1",
    "prettier": "3.7.4",
    "rimraf": "6.1.2",
    "semantic-release": "25.0.2",
    "ts-node": "10.9.2",
    "ts-patch": "4.0.1",
    "tsc-watch": "7.2.0",
    "typescript": "6.0.3",
    "typescript-transform-paths": "4.0.0",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">= 20.8.1"
  },
  "license": "MIT",
  "type": "module",
  "main": "lib/index.js",
  "exports": {
    ".": "./lib/index.js",
    "./npm": "./lib/npm.js",
    "./gradle": "./lib/gradle.js",
    "./gradle-and-npm": "./lib/gradle-and-npm.js",
    "./openapi": "./lib/openapi.js",
    "./lib/index": "./lib/index.js",
    "./lib/index.js": "./lib/index.js",
    "./lib/npm": "./lib/npm.js",
    "./lib/npm.js": "./lib/npm.js",
    "./lib/gradle": "./lib/gradle.js",
    "./lib/gradle.js": "./lib/gradle.js",
    "./lib/gradle-and-npm": "./lib/gradle-and-npm.js",
    "./lib/gradle-and-npm.js": "./lib/gradle-and-npm.js",
    "./lib/openapi": "./lib/openapi.js",
    "./lib/openapi.js": "./lib/openapi.js"
  },
  "name": "@open-turo/semantic-release-config",
  "peerDependencies": {
    "semantic-release": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-turo/semantic-release-config.git"
  },
  "scripts": {
    "build": "tspc -p ./tsconfig.build.json",
    "clean": "rimraf lib tsconfig.build.tsbuildinfo",
    "lint": "eslint",
    "pretest": "npm run build",
    "test": "vitest run",
    "watch": "clean && tsc-watch -w -p ./tsconfig.build.json --compiler ./node_modules/.bin/tspc"
  },
  "types": "lib/index.d.ts",
  "version": "10.1.1"
}
